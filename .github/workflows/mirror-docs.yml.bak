name: Mirror docs to User Pages

on:
  workflow_dispatch:
  push:
    branches:
      - dev
      - main

jobs:
  sync-docs:
    runs-on: ubuntu-latest

    env:
      PAGES_TOKEN: ${{ secrets.PAGES_TOKEN }}

    steps:
      - uses: actions/checkout@v4

      - name: Clone mzti.github.io
        run: |
         git clone https://x-access-token:${PAGES_TOKEN}@github.com/mzti/mzti.github.io.git target_repo

      - name: Copy mztool.ps1 to root of Pages
        run: |
         cp mztool.ps1 target_repo/mztool.ps1

      - name: Commit and push
        run: |
         cd target_repo
         git config user.name "mzti-bot"
         git config user.email "actions@github.com"
         git add .
         git commit -m "Auto-sync docs from mztool" || echo "No changes"
         git push origin main
